NEXT_PUBLIC_API_HOST=localhost:14000
NEXT_PUBLIC_API_PROTOCOL=http
NEXT_PUBLIC_STATS_API_HOST=http://localhost:8080
NEXT_PUBLIC_NETWORK_NAME=Roko Network
NEXT_PUBLIC_NETWORK_SHORT_NAME=Roko
NEXT_PUBLIC_NETWORK_ID=442
NEXT_PUBLIC_NETWORK_CURRENCY_NAME=ROKO
NEXT_PUBLIC_NETWORK_CURRENCY_SYMBOL=ROKO
NEXT_PUBLIC_NETWORK_CURRENCY_DECIMALS=18
NEXT_PUBLIC_API_BASE_PATH=/
NEXT_PUBLIC_APP_HOST=localhost:14000
NEXT_PUBLIC_APP_PROTOCOL=http
NEXT_PUBLIC_HOMEPAGE_CHARTS=['daily_txs']
NEXT_PUBLIC_VISUALIZE_API_HOST=http://localhost:8081
NEXT_PUBLIC_IS_TESTNET=true
NEXT_PUBLIC_API_WEBSOCKET_PROTOCOL=ws
# NEXT_PUBLIC_API_SPEC_URL removed (deprecated in latest frontend)
NEXT_PUBLIC_NETWORK_RPC_URL=https://roko-testnetv2.ntfork.com
NEXT_PUBLIC_NETWORK_VERIFICATION_TYPE=validation
NEXT_PUBLIC_MARKETPLACE_ENABLED=false
NEXT_PUBLIC_OG_ENHANCED_DATA_ENABLED=true

# Force light theme by default
NEXT_PUBLIC_COLOR_THEME_DEFAULT=light

# --- Roko Network Branding ---

# Logo: use network name text display (no external logo URL needed)
# NEXT_PUBLIC_NETWORK_LOGO=
# NEXT_PUBLIC_NETWORK_ICON=

# Suppress "Blockscout" from page/OG titles
NEXT_PUBLIC_PROMOTE_BLOCKSCOUT_IN_TITLE=false

# Heading font: Rajdhani weight 600 (Google Font)
NEXT_PUBLIC_FONT_FAMILY_HEADING={'name':'Rajdhani','url':'https://fonts.googleapis.com/css2?family=Rajdhani:wght@400;500;600;700&display=swap'}

# Hero banner: Roko brand colors, tagline text
# Background: dark charcoal (#1A202C), white text, Roko blue button
NEXT_PUBLIC_HOMEPAGE_HERO_BANNER_CONFIG={'background':['#1A202C'],'text_color':['white'],'button':{'_default':{'background':['#0078D4'],'text_color':['white']},'_hover':{'background':['#005A9E'],'text_color':['white']}}}

# Color theme overrides: replace Blockscout blue with Roko blue (#0078D4)
# Applied to light mode only; dark mode retains Blockscout defaults.
NEXT_PUBLIC_COLOR_THEME_OVERRIDES={'hover':{'_light':{'value':'rgba(0,120,212,1)'},'_dark':{'value':'rgba(0,120,212,1)'}},'selected':{'control':{'text':{'_light':{'value':'rgba(0,86,151,1)'},'_dark':{'value':'rgba(247,250,252,1)'}},'bg':{'_light':{'value':'rgba(0,120,212,0.08)'},'_dark':{'value':'rgba(255,255,255,0.06)'}}},'option':{'bg':{'_light':{'value':'rgba(0,120,212,1)'},'_dark':{'value':'rgba(0,120,212,1)'}}}},'button':{'primary':{'_light':{'value':'rgba(0,120,212,1)'},'_dark':{'value':'rgba(0,120,212,1)'},'text':{'_light':{'value':'rgba(255,255,255,1)'},'_dark':{'value':'rgba(255,255,255,1)'}}}},'link':{'primary':{'_light':{'value':'rgba(0,120,212,1)'},'_dark':{'value':'rgba(99,179,237,1)'}}}}

